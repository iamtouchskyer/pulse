---
// No props; the empty state is self-contained.
---

<section class="empty" data-testid="empty-state" aria-labelledby="empty-title">
  <svg
    class="icon"
    viewBox="0 0 48 48"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <!--
      Static "horizon + bars" silhouette: a baseline with a few flat bars and a single
      indicator dot. No rotational symmetry, no animation — reads as a calm gauge,
      not a spinner.
    -->
    <line x1="6" y1="36" x2="42" y2="36"></line>
    <rect x="10" y="28" width="5" height="8"></rect>
    <rect x="19" y="22" width="5" height="14"></rect>
    <rect x="28" y="30" width="5" height="6"></rect>
    <circle cx="38.5" cy="32" r="1.75" fill="currentColor" stroke="none"></circle>
  </svg>
  <h2 id="empty-title">No snapshots captured yet</h2>
  <p>
    Pulse takes a daily reading of four repos (opc, memex, logex, blog) and writes it here. The
    first snapshot runs tomorrow at 06:17 UTC.
  </p>
</section>

<style>
  .empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    border: 1px dashed var(--border);
    border-radius: 16px;
    background: var(--surface);
    gap: 0.75rem;
  }
  .icon {
    width: 56px;
    height: 56px;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .empty h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
  }
  .empty p {
    margin: 0;
    max-width: 48ch;
    color: var(--text-muted);
  }
</style>
