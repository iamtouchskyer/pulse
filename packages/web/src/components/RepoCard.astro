---
import type { CardData } from "../lib/loadSnapshots";

interface Props {
  card: CardData;
}
const { card } = Astro.props;

function fmt(n: number | null): string {
  if (n === null) return "—";
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

const headingId = `repo-name-${card.repo}`;
---

<article class="card" data-testid="repo-card" aria-labelledby={headingId}>
  <header class="card-header">
    <h2 id={headingId}>{card.repo}</h2>
    {!card.hasData && <span class="badge">no data</span>}
  </header>
  <dl class="stats">
    <div class="stat stat-primary">
      <dt>stars</dt>
      <dd>{fmt(card.stars)}</dd>
    </div>
    <div class="stat stat-secondary">
      <dt>forks</dt>
      <dd>{fmt(card.forks)}</dd>
    </div>
    <div class="stat stat-secondary">
      <dt>issues</dt>
      <dd>{fmt(card.open_issues)}</dd>
    </div>
  </dl>
</article>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  /* Honor prefers-reduced-motion: only attach hover transition/transform when
     the user has not requested reduced motion. Reduced-motion users get the
     border-color hover (instant, non-vestibular) but no lift. */
  @media (prefers-reduced-motion: no-preference) {
    .card {
      transition:
        transform 0.15s ease,
        border-color 0.15s ease;
    }
    .card:hover {
      transform: translateY(-1px);
    }
  }
  .card:hover {
    border-color: var(--accent);
  }
  .card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  h2 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .badge {
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--bg);
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }
  .stats {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 0.75rem;
    margin: 0;
    align-items: end;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .stat dt {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }
  .stat dd {
    margin: 0;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    font-weight: 700;
  }
  /* Visual hierarchy: stars is the primary metric, ~2× the size of forks/issues. */
  .stat-primary dd {
    font-size: 2rem;
    color: var(--text);
    line-height: 1.1;
  }
  .stat-secondary dd {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.2;
  }
</style>
